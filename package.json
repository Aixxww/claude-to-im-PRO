{
  "name": "claude-to-im-pro",
  "version": "1.0.0",
  "description": "Enhanced Claude-to-IM with official Telegram Plugin features integrated: message editing, emoji reactions, and local photo storage",
  "type": "module",
  "main": "dist/lib/bridge/context.js",
  "types": "dist/lib/bridge/context.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/bridge/context.d.ts",
      "import": "./dist/lib/bridge/context.js"
    },
    "./src/lib/bridge/*.js": {
      "types": "./dist/lib/bridge/*.d.ts",
      "import": "./dist/lib/bridge/*.js"
    },
    "./src/lib/bridge/adapters/*.js": {
      "types": "./dist/lib/bridge/adapters/*.d.ts",
      "import": "./dist/lib/bridge/adapters/*.js"
    },
    "./src/lib/bridge/markdown/*.js": {
      "types": "./dist/lib/bridge/markdown/*.d.ts",
      "import": "./dist/lib/bridge/markdown/*.js"
    },
    "./src/lib/bridge/security/*.js": {
      "types": "./dist/lib/bridge/security/*.d.ts",
      "import": "./dist/lib/bridge/security/*.js"
    }
  },
  "files": [
    "dist",
    "src/lib"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test --import tsx --test-timeout=15000 src/__tests__/unit/bridge-*.test.ts",
    "test": "npm run typecheck && npm run test:unit",
    "example": "npx tsx src/lib/bridge/examples/mock-host.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.62",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "discord.js": "^14.25.1",
    "markdown-it": "^14.1.1",
    "ws": "^8.18.0",
    "undici": "^7.24.5"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aixxww/claude-to-im-PRO.git"
  },
  "bugs": {
    "url": "https://github.com/Aixxww/claude-to-im-PRO/issues"
  },
  "homepage": "https://github.com/Aixxww/claude-to-im-PRO#readme",
  "keywords": [
    "claude",
    "anthropic",
    "telegram",
    "discord",
    "feishu",
    "qq",
    "bridge",
    "bot",
    "messaging",
    "ai",
    "claude-code"
  ],
  "author": "Aixxww",
  "license": "MIT"
}
